{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for SwarmCode",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "shell:allow-execute",
    "shell:allow-open",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "dialog:allow-open",
    "dialog:allow-save",
    "notification:allow-notify",
    "process:allow-restart",
    {
      "identifier": "allow-main-commands",
      "allow": [
        "fs_list_dir",
        "fs_read_file",
        "fs_write_file",
        "fs_create_file",
        "fs_delete_file",
        "fs_rename",
        "fs_open_dialog",
        "fs_save_dialog",
        "fs_get_workspace",
        "fs_set_workspace",
        "chat_send_message",
        "chat_get_models",
        "chat_clear_history",
        "chat_compact_history",
        "chat_get_cost",
        "providers_list",
        "providers_test",
        "providers_set_model",
        "providers_get_config_path",
        "providers_read_config",
        "providers_write_config",
        "agents_list",
        "agents_start_swarm",
        "agents_send_message",
        "agents_get_hive_status",
        "terminal_run",
        "terminal_run_in_workspace",
        "app_get_version",
        "app_open_settings"
      ]
    }
  ]
}
